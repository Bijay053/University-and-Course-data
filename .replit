modules = ["nodejs-24", "python-3.12", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "backend-py: FastAPI"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "backend-py: Celery worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis"

[[workflows.workflow]]
name = "backend-py: FastAPI"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend-py && PYTHONPATH=. python -m uvicorn app.main:app --host 0.0.0.0 --port 8080 --reload"
waitForPort = 8080

[[workflows.workflow]]
name = "backend-py: Celery worker"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend-py && PYTHONPATH=. celery -A app.tasks.celery_app worker --concurrency=4 --loglevel=info -Q scrape --beat"

[[workflows.workflow]]
name = "Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --bind 127.0.0.1 --port 6379 --save \"\" --appendonly no --loglevel notice"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 20675
externalPort = 3000

[[ports]]
localPort = 20676
externalPort = 3003

[[ports]]
localPort = 20677
externalPort = 4200

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql", "rapidfuzz-cpp", "taskflow", "xcodebuild", "zlib"]
